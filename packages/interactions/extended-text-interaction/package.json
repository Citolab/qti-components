{
  "name": "@qti-components/extended-text-interaction",
  "description": "QTI extended-text-interaction interaction",
  "version": "1.1.3",
  "author": "",
  "dependencies": {
    "@qti-components/base": "workspace:^",
    "@qti-components/interactions-core": "workspace:^",
    "@qti-components/utilities": "workspace:^"
  },
  "devDependencies": {
    "@lit/context": "^1.1.6",
    "lit": "^3.3.2"
  },
  "keywords": [
    "interactions",
    "qti",
    "extended-text-interaction"
  ],
  "license": "GPL-3.0-only",
  "main": "dist/index.js",
  "peerDependencies": {
    "@lit/context": "^1.1.6",
    "lit": "^3.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "attw": "attw --profile esm-only --pack",
    "build": "tsc --paths null",
    "clean": "rm -rf dist",
    "publish": "node ../../../tools/publish-if-needed.mjs"
  },
  "sideEffects": true,
  "type": "module",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./*": "./dist/*",
    "./styles": {
      "types": "./dist/qti-extended-text-interaction.styles.d.ts",
      "import": "./dist/qti-extended-text-interaction.styles.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Citolab/qti-components.git",
    "directory": "packages/interactions/extended-text-interaction"
  }
}
