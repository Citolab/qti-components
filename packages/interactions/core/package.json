{
  "name": "@qti-components/interactions-core",
  "description": "QTI interactions shared core (mixins, internal, elements)",
  "version": "1.0.0",
  "author": "",
  "dependencies": {
    "@qti-components/base": "workspace:^",
    "@qti-components/utilities": "workspace:^",
    "observable-polyfill": "^0.0.29"
  },
  "devDependencies": {
    "@lit/context": "^1.1.6",
    "lit": "^3.3.1"
  },
  "keywords": [
    "interactions",
    "qti",
    "core"
  ],
  "license": "GPL-3.0-only",
  "main": "dist/index.js",
  "peerDependencies": {
    "@lit/context": "^1.1.6",
    "lit": "^3.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "attw": "attw --profile esm-only --pack",
    "build": "tsc --paths null",
    "clean": "rm -rf dist",
    "release": "semantic-release --no-ci",
    "release:semantic": "semantic-release --no-ci",
    "release:semantic:dry-run": "semantic-release --dry-run --no-ci",
    "publish": "node ../../../tools/publish-if-needed.mjs"
  },
  "sideEffects": true,
  "type": "module",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./mixins/drag-drop-observables": {
      "types": "./dist/mixins/drag-drop-observables/index.d.ts",
      "import": "./dist/mixins/drag-drop-observables/index.js"
    },
    "./elements/*": {
      "types": "./dist/elements/*/index.d.ts",
      "import": "./dist/elements/*/index.js"
    },
    "./mixins/*": {
      "types": "./dist/mixins/*.d.ts",
      "import": "./dist/mixins/*.js"
    },
    "./internal/*": {
      "types": "./dist/internal/*.d.ts",
      "import": "./dist/internal/*.js"
    },
    "./*": "./dist/*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Citolab/qti-components.git",
    "directory": "packages/interactions/core"
  }
}
