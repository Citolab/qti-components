    "@qti-components/graphic-gap-match-interaction": "workspace:^",
    "@qti-components/graphic-order-interaction": "workspace:^",
    "@qti-components/hotspot-interaction": "workspace:^",
    "@qti-components/hottext-interaction": "workspace:^",
    "@qti-components/inline-choice-interaction": "workspace:^",
    "@qti-components/interactions-core": "workspace:^",
    "@qti-components/match-interaction": "workspace:^",
    "@qti-components/media-interaction": "workspace:^",
    "@qti-components/order-interaction": "workspace:^",
    "@qti-components/portable-custom-interaction": "workspace:^",
    "@qti-components/position-object-interaction": "workspace:^",
    "@qti-components/select-point-interaction": "workspace:^",
    "@qti-components/slider-interaction": "workspace:^",
    "@qti-components/text-entry-interaction": "workspace:^",
    "@qti-components/upload-interaction": "workspace:^"
  },
  "devDependencies": {
    "@lit/context": "^1.1.6",
    "@qti-components/theme": "workspace:^",
    "@qti-components/transformers": "workspace:^",
    "lit": "^3.3.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register-all": {
      "types": "./dist/register-all.d.ts",
      "import": "./dist/register-all.js"
    },
    "./mixins/drag-drop-observables": {
      "types": "./dist/mixins/drag-drop-observables/index.d.ts",
      "import": "./dist/mixins/drag-drop-observables/index.js"
    },
    "./*": "./dist/*"
  },
  "files": [
    "dist/**/*"
  ],
  "keywords": [
    "interactions",
    "qti"
  ],
  "license": "GPL-3.0-only",
  "main": "dist/index.js",
  "peerDependencies": {
    "@lit/context": "^1.1.6",
    "lit": "^3.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "attw": "attw --profile esm-only --pack",
    "build": "tsc --paths null",
    "build-storybook": "storybook build",
    "cem": "cem analyze --config ./custom-elements-manifest.config.mjs",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6008 --no-open",
    "yalc": "yalc publish",
    "yalc:push": "yalc push",
    "publish": "node ../../tools/publish-if-needed.mjs"
  },
  "sideEffects": true,
  "type": "module",
  "types": "dist/index.d.ts",
  "customElements": "custom-elements.json",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Citolab/qti-components.git",
    "directory": "packages/qti-interactions"
  }
