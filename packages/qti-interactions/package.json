{
  "name": "@qti-components/interactions",
  "description": "QTI interactions utilities",
  "version": "1.10.1",
  "author": "",
  "dependencies": {
    "@qti-components/associate-interaction": "workspace:^",
    "@qti-components/choice-interaction": "workspace:^",
    "@qti-components/custom-interaction": "workspace:^",
    "@qti-components/end-attempt-interaction": "workspace:^",
    "@qti-components/extended-text-interaction": "workspace:^",
    "@qti-components/gap-match-interaction": "workspace:^",
