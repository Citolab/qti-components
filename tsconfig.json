        "./packages/qti-components/src/index.ts"
      ],
      "@qti-components/base": [
        "./packages/qti-base/src/index.ts"
      ],
      "@qti-components/elements": [
        "./packages/qti-elements/src/index.ts"
      ],
      "@qti-components/interactions": [
