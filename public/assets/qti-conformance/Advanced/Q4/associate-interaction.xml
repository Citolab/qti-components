<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item
    xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd"
    identifier="q4-associate-interaction"
    title="Q4 - Associate Interaction"
    adaptive="false" time-dependent="false">
    <qti-response-declaration identifier="RESPONSE" cardinality="multiple" base-type="pair"></qti-response-declaration>
    <qti-item-body>
        <qti-associate-interaction response-identifier="RESPONSE" shuffle="false" max-associations="0">
            <qti-prompt></qti-prompt>
            <qti-simple-associable-choice identifier="A" match-max="1">choice_a</qti-simple-associable-choice>
            <qti-simple-associable-choice identifier="B" match-max="1">choice_b</qti-simple-associable-choice>
            <qti-simple-associable-choice identifier="C" match-max="1">choice_c</qti-simple-associable-choice>
            <qti-simple-associable-choice identifier="D" match-max="1">choice_d</qti-simple-associable-choice>
        </qti-associate-interaction>
    </qti-item-body>
</qti-assessment-item>
